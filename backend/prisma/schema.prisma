// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid()) @db.Uuid
  username String @unique @db.VarChar(50)
  password_hash String @db.VarChar(255)
  role String @db.VarChar(20)
  local_base_dir String @db.VarChar(512)
  remote_base_dir String @db.VarChar(512)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  serverCredentials ServerCredential[]
  jobBundles JobBundle[]
}

model ServerCredential {
  id String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  hostname String @db.VarChar(255)
  username String @db.VarChar(50)
  passwordEncrypted String? @db.Text
  sshKeyPath String? @db.VarChar(512)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])
}

model JobBundle {
  id String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  name String @db.VarChar(255)
  description String? @db.Text
  calcTypeName String @db.VarChar(50)
  theoryLevel String @db.VarChar(50)
  basisSet String @db.VarChar(50)
  solventModel String? @db.VarChar(50)
  solventName String? @db.VarChar(50)
  memGb Decimal? @db.Decimal(5, 2)
  nprocShared Int? @db.Integer
  additionalKeywords String? @db.Text
  status String @db.VarChar(50)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])
  molecules Molecule[]
}

model Molecule {
  id              String   @id @default(uuid())           @db.Uuid
  jobBundleId     String                                  @db.Uuid
  name            String                                  @db.VarChar(255)
  charge          Int                                     @db.SmallInt
  multiplicity    Int                                     @db.SmallInt
  atomCount       Int                                     @db.Integer
  localGjfPath    String                                  @db.VarChar(512)
  inputXyzCoords  String                                  @db.Text
  createdAt       DateTime @default(now())              @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt                   @db.Timestamptz(6)

  jobBundle JobBundle @relation(fields: [jobBundleId], references: [id])
  jobs      Job[]
}

model Job {
  id                String   @id @default(uuid())         @db.Uuid
  moleculeId        String                                  @db.Uuid
  gaussianJobId     String?                                @db.VarChar(100)
  status            String                                  @db.VarChar(50)
  remoteJobDirPath  String                                  @db.VarChar(512)
  startTime         DateTime?                              @db.Timestamptz(6)
  endTime           DateTime?                              @db.Timestamptz(6)
  errorMessage      String?                                @db.Text
  lastLogUpdateAt   DateTime?                              @db.Timestamptz(6)
  createdAt         DateTime @default(now())              @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt                   @db.Timestamptz(6)

  molecule      Molecule         @relation(fields: [moleculeId], references: [id])
  summaryResult JobSummaryResult?
}

model JobSummaryResult {
  id                       String   @id @default(uuid())  @db.Uuid
  jobId                    String   @unique               @db.Uuid
  finalEnergyHartree       Decimal?                      @db.Decimal(18, 10)
  finalEnergyZpeHartree    Decimal?                      @db.Decimal(18, 10)
  finalEnergyHHartree      Decimal?                      @db.Decimal(18, 10)
  finalEnergyGHartree      Decimal?                      @db.Decimal(18, 10)
  homoEnergyEv             Decimal?                      @db.Decimal(10, 5)
  lumoEnergyEv             Decimal?                      @db.Decimal(10, 5)
  bandGapEv                Decimal?                      @db.Decimal(10, 5)
  lowestExcitationEnergyEv Decimal?                      @db.Decimal(10, 5)
  lowestOscillatorStrength Decimal?                      @db.Decimal(10, 5)
  extractedAt              DateTime                      @db.Timestamptz(6)

  job Job @relation(fields: [jobId], references: [id])
}